-                if architecture0 == 'arm64':
-                    pep600_architecture = 'aarch64'
-                else:
-                    pep600_architecture = architecture0
-
-                oses = 'manylinux_2_28_{}'.format(pep600_architecture)
-            else:
-                pythons = 'py2.py3'
-                oses = 'any'
-            return pythons, 'none', oses
